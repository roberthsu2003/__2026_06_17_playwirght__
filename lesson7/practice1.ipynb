   "source": [
    "## while迴圈"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "35828789-3358-43db-af0b-fa139f123b9a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "6\n",
      "5\n",
      "4\n",
      "3\n",
      "2\n",
      "1\n",
      "離開後 a 為 0\n"
     ]
    }
   ],
   "source": [
    "# while1.py\n",
    "a = 6\n",
    "while a > 0:\n",
    "    print(a)\n",
    "    a -= 1 \n",
    "print(\"離開後 a 為\", a)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "e89a1c99-a6d2-4c91-9748-225871f4ecf2",
   "metadata": {},
   "source": [
    "## 計算 2-10 所有偶數的總和"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "e4c0e864-8063-4766-a1cb-2ca54589c993",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "第1次迴圈的i=2,總合為2\n",
      "第2次迴圈的i=4,總合為6\n",
      "第3次迴圈的i=6,總合為12\n",
      "第4次迴圈的i=8,總合為20\n",
      "第5次迴圈的i=10,總合為30\n"
     ]
    }
   ],
   "source": [
    "total = 0\n",
    "i = 2\n",
    "while i <= 10:\n",
    "    total += i\n",
    "    print(f\"第{i//2}次迴圈的i={i},總合為{total}\")\n",
    "    i += 2"
   ]
  },
